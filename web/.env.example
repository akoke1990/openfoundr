# OpenFounder Web — Environment Variables
# Copy to .env.local and fill in your values

# AI (Groq)
GROQ_API_KEY=your_groq_key_here

# Supabase (https://supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resend email (https://resend.com → API Keys)
RESEND_API_KEY=re_your_key_here
# Must be a verified domain in Resend, or use onboarding@resend.dev for testing
RESEND_FROM_EMAIL=OpenFounder <hello@yourdomain.com>

# Your app's public URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Tavily web search (https://tavily.com — free tier: 1000 searches/month)
TAVILY_API_KEY=tvly-your-key-here

# Cron secret — authenticate /api/reminders/send. Use any random string.
# Vercel sets Authorization: Bearer {CRON_SECRET} automatically for cron jobs.
CRON_SECRET=your-random-secret-here
